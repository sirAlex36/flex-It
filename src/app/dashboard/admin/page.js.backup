"use client";

import { useState, useEffect } from "react";
import { useRouter } from "next/navigation";
import Header from "@/components/Header";
import Footer from "@/components/Footer";
import {
  StatCard,
  Modal,
  Alert,
  Table,
  Badge,
  Tabs,
  LoadingSkeleton,
  EmptyState,
} from "@/components/AdminComponents";
import {
  getEvents,
  getTickets,
  createEvent,
  updateEvent,
  deleteEvent,
  getTransactions,
  getUsers,
} from "@/lib/api";
import {
  PlusIcon,
  ArrowTrendingUpIcon,
  TicketIcon,
  CalendarDaysIcon,
  UserGroupIcon,
  CreditCardIcon,
  EyeIcon,
  TrashIcon,
  CheckCircleIcon,
  ExclamationTriangleIcon,
} from "@heroicons/react/24/outline";

export default function AdminDashboard() {
  const router = useRouter();
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [success, setSuccess] = useState(null);

  // Data states
  const [events, setEvents] = useState([]);
  const [tickets, setTickets] = useState([]);
  const [users, setUsers] = useState([]);
  const [transactions, setTransactions] = useState([]);

  // UI states
  const [activeTab, setActiveTab] = useState("overview");
  const [showEventModal, setShowEventModal] = useState(false);
  const [showDeleteModal, setShowDeleteModal] = useState(false);
  const [selectedEvent, setSelectedEvent] = useState(null);
  const [formLoading, setFormLoading] = useState(false);

  const [eventForm, setEventForm] = useState({
    name: "",
    date: "",
    venue: "",
    description: "",
    image: "",
  });

  // Check authentication
  useEffect(() => {
    const token = localStorage.getItem("token");
    if (!token) {
      router.push("/login");
      return;
    }

    try {
      // Parse token to get user info
      const parts = token.split(".");
      const payload = JSON.parse(atob(parts[1]));
      if (payload.role !== "admin") {
        router.push("/");
        return;
      }
      setUser(payload);
    } catch (err) {
      router.push("/login");
    }
  }, [router]);

  // Fetch data
  useEffect(() => {
    if (user) {
      fetchAllData();
    }
  }, [user]);

  const fetchAllData = async () => {
    setLoading(true);
    setError(null);
    try {
      const [eventsData, ticketsData, usersData] = await Promise.all([
        getEvents(),
        getTickets(),
        getUsers(),
      ]);

      setEvents(eventsData || []);
      setTickets(ticketsData || []);
      setUsers(usersData || []);

      // Fetch transactions for latest tickets
      if (ticketsData && ticketsData.length > 0) {
        const latestTicket = ticketsData[0];
        try {
          const transData = await getTransactions(latestTicket.id);
          setTransactions(transData || []);
        } catch (err) {
          console.error("Error fetching transactions:", err);
        }
      }
    } catch (err) {
      setError(err.message);
      console.error("Error fetching data:", err);
    } finally {
      setLoading(false);
    }
  };

  const handleEventSave = async (e) => {
    e.preventDefault();
    setFormLoading(true);
    setError(null);

    try {
      if (selectedEvent?.id) {
        await updateEvent(selectedEvent.id, eventForm);
        setSuccess("Event updated successfully!");
      } else {
        await createEvent(eventForm);
        setSuccess("Event created successfully!");
      }

      setShowEventModal(false);
      resetEventForm();
      await fetchAllData();

      setTimeout(() => setSuccess(null), 3000);
    } catch (err) {
      setError(err.message);
    } finally {
      setFormLoading(false);
    }
  };

  const handleDeleteEvent = async () => {
    setFormLoading(true);
    try {
      await deleteEvent(selectedEvent.id);
      setSuccess("Event deleted successfully!");
      setShowDeleteModal(false);
      setSelectedEvent(null);
      await fetchAllData();
      setTimeout(() => setSuccess(null), 3000);
    } catch (err) {
      setError(err.message);
    } finally {
      setFormLoading(false);
    }
  };

  const openEventModal = (event = null) => {
    if (event) {
      setSelectedEvent(event);
      setEventForm({
        name: event.name,
        date: event.date,
        venue: event.venue,
        description: event.description || "",
        image: event.image || "",
      });
    } else {
      resetEventForm();
    }
    setShowEventModal(true);
  };

  const resetEventForm = () => {
    setEventForm({ name: "", date: "", venue: "", description: "", image: "" });
    setSelectedEvent(null);
  };

  // Calculate stats
  const upcomingEvents = events.filter((e) => new Date(e.date) >= new Date());
  const confirmedTickets = tickets.filter((t) => t.mpesa_status === "confirmed");
  const pendingTickets = tickets.filter((t) => t.mpesa_status === "pending");
  const totalRevenue = confirmedTickets.reduce((sum, t) => sum + (t.price || 0) * (t.quantity || 1), 0);

  const tabs = [
    { id: "overview", label: "Overview", count: null },
    { id: "events", label: "Events", count: events.length },
    { id: "tickets", label: "Tickets", count: tickets.length },
    { id: "transactions", label: "Transactions", count: transactions.length },
    { id: "users", label: "Users", count: users.length },
  ];

  if (loading && activeTab === "overview") {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gray-50">
        <div className="text-center">
          <div className="animate-spin rounded-full h-16 w-16 border-b-2 border-blue-600 mx-auto mb-4" />
          <p className="text-gray-600">Loading dashboard...</p>
        </div>
      </div>
    );
  }

  return (
    <>
      <Header />
      <main className="min-h-screen bg-gray-50">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          {/* Header */}
          <div className="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h1 className="text-4xl font-bold text-gray-900">Admin Dashboard</h1>
              <p className="text-gray-600 mt-1">Welcome back, {user?.name || "Admin"}</p>
            </div>
            <button
              onClick={() => openEventModal()}
              className="inline-flex items-center gap-2 px-4 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-sm"
            >
              <PlusIcon className="h-5 w-5" />
              Add Event
            </button>
          </div>

          {/* Alerts */}
          {error && <Alert type="error" message={error} onClose={() => setError(null)} />}
          {success && <Alert type="success" message={success} onClose={() => setSuccess(null)} />}

          {/* Stats Grid */}
          {activeTab === "overview" && (
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
              <StatCard
                icon={CalendarDaysIcon}
                label="Total Events"
                value={events.length}
                change={{ positive: true, percent: 12 }}
              />
              <StatCard
                icon={ArrowTrendingUpIcon}
                label="Upcoming"
                value={upcomingEvents.length}
              />
              <StatCard
                icon={TicketIcon}
                label="Tickets Sold"
                value={confirmedTickets.length}
                change={{ positive: true, percent: 8 }}
              />
              <StatCard
                icon={CreditCardIcon}
                label="Revenue"
                value={`KES ${totalRevenue.toLocaleString()}`}
                change={{ positive: true, percent: 15 }}
              />
              <StatCard
                icon={UserGroupIcon}
                label="Total Users"
                value={users.length}
              />
            </div>
          )}

          {/* Tabs */}
          <div className="mb-6">
            <Tabs tabs={tabs} activeTab={activeTab} onTabChange={setActiveTab} />
          </div>

          {/* Overview Tab */}
          {activeTab === "overview" && (
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
              {/* Recent Events */}
              <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
                <div className="px-6 py-4 border-b border-gray-100">
                  <h2 className="text-lg font-semibold text-gray-900">Recent Events</h2>
                </div>
                <div className="divide-y divide-gray-100">
                  {events.slice(0, 5).map((event) => (
                    <div key={event.id} className="px-6 py-4 hover:bg-gray-50 transition-colors">
                      <div className="flex items-start gap-4">
                        <img
                          src={event.image || "https://via.placeholder.com/64x64?text=Event"}
                          alt={event.name}
                          className="h-16 w-16 object-cover rounded-lg"
                          onError={(e) => (e.target.src = "https://via.placeholder.com/64x64?text=Event")}
                        />
                        <div className="flex-1">
                          <h3 className="font-semibold text-gray-900">{event.name}</h3>
                          <p className="text-sm text-gray-600 mt-1">
                            📍 {event.venue} • 📅 {new Date(event.date).toLocaleDateString()}
                          </p>
                        </div>
                      </div>
                    </div>
                  ))}
                  {events.length === 0 && (
                    <div className="px-6 py-8 text-center text-gray-500">No events yet</div>
                  )}
                </div>
              </div>

              {/* Recent Transactions */}
              <div className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
                <div className="px-6 py-4 border-b border-gray-100">
                  <h2 className="text-lg font-semibold text-gray-900">Recent Transactions</h2>
                </div>
                <div className="divide-y divide-gray-100">
                  {transactions.slice(0, 5).map((trans) => (
                    <div key={trans.id} className="px-6 py-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
                      <div className="flex items-center gap-3">
                        {trans.status === "success" ? (
                          <CheckCircleIcon className="h-5 w-5 text-green-600" />
                        ) : (
                          <ExclamationTriangleIcon className="h-5 w-5 text-yellow-600" />
                        )}
                        <div>
                          <p className="text-sm font-medium text-gray-900">Ticket #{trans.id}</p>
                          <p className="text-xs text-gray-500">{new Date(trans.initiated_at).toLocaleDateString()}</p>
                        </div>
                      </div>
                      <div className="text-right">
                        <p className="text-sm font-semibold text-gray-900">KES {trans.amount}</p>
                        <Badge type={trans.status === "success" ? "success" : "warning"} text={trans.status} size="sm" />
                      </div>
                    </div>
                  ))}
                  {transactions.length === 0 && (
                    <div className="px-6 py-8 text-center text-gray-500">No transactions yet</div>
                  )}
                </div>
              </div>
            </div>
          )}

          {/* Events Tab */}
          {activeTab === "events" && (
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {events.length === 0 ? (
                <div className="col-span-full">
                  <EmptyState
                    icon={CalendarDaysIcon}
                    title="No events yet"
                    description="Create your first event to get started"
                    action={{ label: "Add Event", onClick: () => openEventModal() }}
                  />
                </div>
              ) : (
                events.map((event) => (
                  <div key={event.id} className="bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                    <img
                      src={event.image || "https://via.placeholder.com/400x200?text=Event"}
                      alt={event.name}
                      className="h-48 w-full object-cover"
                      onError={(e) => (e.target.src = "https://via.placeholder.com/400x200?text=Event")}
                    />
                    <div className="p-4">
                      <h3 className="text-lg font-semibold text-gray-900">{event.name}</h3>
                      <p className="text-sm text-gray-600 mt-2">
                        📍 {event.venue}<br />
                        📅 {new Date(event.date).toLocaleDateString()}
                      </p>
                      <p className="text-sm text-gray-700 mt-3 line-clamp-2">{event.description || "No description"}</p>
                      <div className="mt-4 flex gap-2">
                        <button
                          onClick={() => openEventModal(event)}
                          className="flex-1 px-3 py-2 text-sm font-medium text-blue-600 border border-blue-200 rounded-lg hover:bg-blue-50 transition-colors flex items-center justify-center gap-1"
                        >
                          <EyeIcon className="h-4 w-4" />
                          Edit
                        </button>
                        <button
                          onClick={() => {
                            setSelectedEvent(event);
                            setShowDeleteModal(true);
                          }}
                          className="flex-1 px-3 py-2 text-sm font-medium text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition-colors flex items-center justify-center gap-1"
                        >
                          <TrashIcon className="h-4 w-4" />
                          Delete
                        </button>
                      </div>
                    </div>
                  </div>
                ))
              )}
            </div>
          )}

          {/* Tickets Tab */}
          {activeTab === "tickets" && (
            <Table
              columns={[
                { key: "id", label: "Ticket ID" },
                {
                  key: "ticket_type",
                  label: "Type",
                  render: (value) => <Badge text={value} />,
                },
                {
                  key: "price",
                  label: "Price",
                  render: (value) => `KES ${value}`,
                },
                {
                  key: "mpesa_status",
                  label: "Status",
                  render: (value) => (
                    <Badge
                      type={value === "confirmed" ? "success" : value === "pending" ? "warning" : "error"}
                      text={value || "Unknown"}
                    />
                  ),
                },
                {
                  key: "user_id",
                  label: "User",
                  render: (value) => `User #${value}`,
                },
                {
                  key: "created_at",
                  label: "Created",
                  render: (value) => new Date(value || Date.now()).toLocaleDateString(),
                },
              ]}
              data={tickets}
              loading={false}
              empty={{ title: "No tickets", description: "No tickets have been created yet" }}
            />
          )}

          {/* Transactions Tab */}
          {activeTab === "transactions" && (
            <Table
              columns={[
                { key: "id", label: "Transaction ID" },
                {
                  key: "amount",
                  label: "Amount",
                  render: (value) => `KES ${value}`,
                },
                {
                  key: "mpesa_receipt",
                  label: "Receipt",
                  render: (value) => value || "Pending",
                },
                {
                  key: "status",
                  label: "Status",
                  render: (value) => (
                    <Badge
                      type={value === "success" ? "success" : value === "failed" ? "error" : "warning"}
                      text={value}
                    />
                  ),
                },
                {
                  key: "payment_method",
                  label: "Method",
                  render: (value) => value || "Unknown",
                },
                {
                  key: "initiated_at",
                  label: "Date",
                  render: (value) => new Date(value).toLocaleDateString(),
                },
              ]}
              data={transactions}
              loading={false}
              empty={{ title: "No transactions", description: "No transactions yet" }}
            />
          )}

          {/* Users Tab */}
          {activeTab === "users" && (
            <Table
              columns={[
                { key: "id", label: "User ID" },
                { key: "name", label: "Name" },
                { key: "email", label: "Email" },
                {
                  key: "role",
                  label: "Role",
                  render: (value) => (
                    <Badge type={value === "admin" ? "info" : "default"} text={value || "User"} />
                  ),
                },
              ]}
              data={users}
              loading={false}
              empty={{ title: "No users", description: "No users found" }}
            />
          )}
        </div>
      </main>

      {/* Event Modal */}
      <Modal
        isOpen={showEventModal}
        onClose={() => {
          setShowEventModal(false);
          resetEventForm();
        }}
        title={selectedEvent ? "Edit Event" : "Add New Event"}
        size="lg"
      >
        <form onSubmit={handleEventSave} className="space-y-6">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">Event Name</label>
              <input
                type="text"
                value={eventForm.name}
                onChange={(e) => setEventForm({ ...eventForm, name: e.target.value })}
                required
                className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                placeholder="Enter event name"
              />
            </div>
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">Date</label>
              <input
                type="date"
                value={eventForm.date}
                onChange={(e) => setEventForm({ ...eventForm, date: e.target.value })}
                required
                className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">Venue</label>
            <input
              type="text"
              value={eventForm.venue}
              onChange={(e) => setEventForm({ ...eventForm, venue: e.target.value })}
              required
              className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="Enter venue name"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">Image URL</label>
            <input
              type="url"
              value={eventForm.image}
              onChange={(e) => setEventForm({ ...eventForm, image: e.target.value })}
              className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="https://example.com/image.jpg"
            />
          </div>

          <div>
            <label className="block text-sm font-medium text-gray-700 mb-2">Description</label>
            <textarea
              value={eventForm.description}
              onChange={(e) => setEventForm({ ...eventForm, description: e.target.value })}
              rows={4}
              className="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="Enter event description"
            />
          </div>

          <div className="flex justify-end gap-3 pt-4 border-t">
            <button
              type="button"
              onClick={() => {
                setShowEventModal(false);
                resetEventForm();
              }}
              className="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors font-medium"
            >
              Cancel
            </button>
            <button
              type="submit"
              disabled={formLoading}
              className="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium disabled:opacity-50"
            >
              {formLoading ? "Saving..." : selectedEvent ? "Update Event" : "Create Event"}
            </button>
          </div>
        </form>
      </Modal>

      {/* Delete Confirmation Modal */}
      <Modal
        isOpen={showDeleteModal}
        onClose={() => {
          setShowDeleteModal(false);
          setSelectedEvent(null);
        }}
        title="Delete Event"
        size="sm"
      >
        <div className="space-y-4">
          <p className="text-gray-700">
            Are you sure you want to delete <strong>{selectedEvent?.name}</strong>? This action cannot be undone.
          </p>
          <div className="flex justify-end gap-3 pt-4 border-t">
            <button
              onClick={() => {
                setShowDeleteModal(false);
                setSelectedEvent(null);
              }}
              className="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors"
            >
              Cancel
            </button>
            <button
              onClick={handleDeleteEvent}
              disabled={formLoading}
              className="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors disabled:opacity-50"
            >
              {formLoading ? "Deleting..." : "Delete"}
            </button>
          </div>
        </div>
      </Modal>

      <Footer />
    </>
  );
}
